local function StartSpectating(player)
    if not player then return end
    SpectatingTarget = player
    pcall(function()
        if player.Character then
            local targetSubject = player.Character:FindFirstChildOfClass("Humanoid") or player.Character:FindFirstChild("HumanoidRootPart")
            if targetSubject then
                Camera.CameraSubject = targetSubject
                Camera.CameraType = Enum.CameraType.Custom
            end

-- Dynamic Character Harvester Function
local function GetABACharacters()
    local characterList = {}
    pcall(function()
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        local hud = playerGui and playerGui:FindFirstChild("HUD")
        local charSelect = hud and hud:FindFirstChild("CharacterSelect")
        local charactersFolder = charSelect and charSelect:FindFirstChild("Characters")
        
        if charactersFolder then
            for _, page in pairs(charactersFolder:GetChildren()) do
                for _, series in pairs(page:GetChildren()) do
                    local slotsFolder = series:FindFirstChild("Slots")
                    if slotsFolder then
                        for _, slot in pairs(slotsFolder:GetChildren()) do
                            if not table.find(characterList, slot.Name) then
                                table.insert(characterList, slot.Name)
                            end
                        end
                    end
                end
            end
        end
    end)
    
    if #characterList == 0 then
        characterList = {"Goku", "Luffy", "Ichigo", "Naruto [Shippuden]", "Sasuke"}
    end
    
    table.sort(characterList)
    return characterList
end


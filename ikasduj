                        if os.time() - timestamp < 8 then
                            table.insert(botList, bName)
                        end
                    end
                end
                table.sort(botList)
               
                BotIndexGlobal = table.find(botList, LocalPlayer.Name) or 1
                TotalBotsGlobal = #botList > 0 and #botList or 1
                
                for _, player in pairs(Players:GetPlayers()) do
                    CheckPlayerForStaff(player)
                end

                if data.ForcedCharacter and data.ForcedCharacter ~= lastForcedChar and data.ForcedCharacter ~= "" then

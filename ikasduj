-- --- SAFE FILE UTILITIES ---
local function GetClusterData()
    local success, content = pcall(function() return readfile(SharedFileName) end)
    if success and content and content ~= "" then
        local ok, data = pcall(function() return HttpService:JSONDecode(content) end)
        if ok and data then return data end
    end
    return { Command = "STOP", Target = "", OrbitSpeed = 22, OrbitRadius = 6, AutoM1 = false, InfiniteCombo = false, M1Frequency = 0.22, InfiniteWindow = 1.4, Moves = {false, false, false, false}, ForcedCharacter = "", ChatSpam = false, ActiveBots = {}, ModDetector = { Enabled = false, Action = "Alert Only", GroupCheck = true, GroupID = 313075, MinRank = 10, CustomList = {}, SoundAlert = true, Volume = 2.0 } }
end

local function SaveClusterData(data)
    pcall(function()
        writefile(SharedFileName, HttpService:JSONEncode(data))
    end)
end


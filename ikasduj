                ChatSpamActiveGlobal = data.ChatSpam or false
        
                if data.ModDetector then
                    ModDetectorEnabled = data.ModDetector.Enabled or false
                    DetectorAction = data.ModDetector.Action or "Alert Only"
                    GroupCheckEnabled = data.ModDetector.GroupCheck ~= false
                    GroupIdCheckValue = data.ModDetector.GroupID or 313075
                    MinRankCheckValue = data.ModDetector.MinRank or 10

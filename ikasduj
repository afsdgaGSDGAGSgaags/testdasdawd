            CachedInputRemote = nil
        end)

        -- Command Listener Loop
        task.spawn(function()
            while Running do
                local data = GetClusterData()
        
                AutoM1ActiveGlobal = data.AutoM1 or false
                InfiniteComboGlobal = data.InfiniteCombo or false 
                ActiveCommandGlobal = data.Command or "STOP"
                MoveTogglesGlobal = data.Moves or {false, false, false, false}
                
